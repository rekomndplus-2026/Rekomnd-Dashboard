# ── Facebook Session ───────────────────────────────────────
# Path to the Playwright storage state JSON file
FB_SESSION_FILE=data/fb_session.json

# ── Telegram (optional) ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Commenter Settings ────────────────────────────────────
MAX_POSTS_PER_GROUP=10
COMMENT_MIN_DELAY=30
COMMENT_MAX_DELAY=90
